# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# Backend
ENVIRONMENT=development
APP_NAME=Valenix
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql+asyncpg://valenix:valenix@postgres:5432/valenix
REDIS_URL=redis://redis:6379/0
SESSION_SECRET=change-me-in-development
SESSION_COOKIE_NAME=valenix_session
SESSION_EXPIRE_MINUTES=10080
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Optional Ollama integration. Leave blank to use the local fallback streamer.
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=120
